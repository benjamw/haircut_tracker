# Copy to .env and adjust as needed.
#
# Docker: docker-compose sets these as real env vars (this file's DB_HOST=db etc.
# are the container names).
#
# Shared hosting (no env vars): put a .env file at api/.env — src/Support/Dotenv
# reads it into PHP. Use the host's real values, e.g.:
#   DB_HOST=localhost   DB_USER=<cpanel_db_user>   DB_PASSWORD=<...>   DB_NAME=<...>
#   SMTP_HOST=<host smtp>   SMTP_PORT=465   SMTP_SECURE=smtps
#   SMTP_USER/PASS=<mailbox creds>
#   AUTH_SECRET=<long random string>   ADMIN_TOKEN=<random>   SHOP_TZ=America/Denver
#   PUBLIC_BASE_URL=https://yourdomain   API_PUBLIC_URL=https://yourdomain/api
# The api/.htaccess + api/public/.htaccess keep .env from being web-served.

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=haircut_tracker
MYSQL_USER=haircut
MYSQL_PASSWORD=haircut

# Temporary admin guard (Phase A/B). Sent as the X-Admin-Token header.
# Replaced by session/passkey auth in Phase C. Leave blank to disable in dev.
ADMIN_TOKEN=dev-admin-token

# Secret for signing user session JWTs (REQUIRED; the API refuses to start if
# empty unless ADMIN_AUTH_DISABLED=1). Change for production.
AUTH_SECRET=dev-secret-change-me

# Dev-only escape hatch: set to 1 to allow admin routes without ADMIN_TOKEN and
# to skip the AUTH_SECRET requirement. NEVER set in production.
ADMIN_AUTH_DISABLED=

# Show error stack traces in API responses. 1 = dev only. Leave blank in prod.
APP_DEBUG=

# Shop timezone — PHP + MySQL both run in this zone so slot cutoffs and hold
# expiry match the shop's wall clock.
SHOP_TZ=America/Denver

# WebAuthn relying-party ID — the site's hostname (no scheme/port). "localhost"
# works for dev; set to your real domain in production (requires HTTPS).
WEBAUTHN_RPID=localhost

# API -> DB connection
DB_HOST=db
DB_PORT=3306
DB_NAME=haircut_tracker
DB_USER=haircut
DB_PASSWORD=haircut

# Ports exposed on the host
API_PORT=8080
WEB_PORT=5173
DB_HOST_PORT=3306

# Frontend -> API base URL (used by Vite dev server in the browser)
VITE_API_BASE=http://localhost:8080

# Mail (dev uses MailHog; UI at http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=bookings@haircut.local
MAIL_FROM_NAME=Haircut Tracker
MAILHOG_UI_PORT=8025

# Booking / verification
HOLD_TTL_MINUTES=10
OTP_TTL_MINUTES=10

# Cloudflare Turnstile (free bot check). Leave both blank to disable.
#  - TURNSTILE_SECRET: server-side secret (API verifies tokens)
#  - VITE_TURNSTILE_SITE_KEY: public site key baked into the frontend build
TURNSTILE_SECRET=
VITE_TURNSTILE_SITE_KEY=

# Set to "1" only when running behind a trusted reverse proxy that sets
# X-Forwarded-For. Blank = derive client IP from REMOTE_ADDR (spoof-proof).
TRUSTED_PROXY=

# Public base URL used in links inside messages
PUBLIC_BASE_URL=http://localhost:5173
# API base URL used for the reminder opt-out link
API_PUBLIC_URL=http://localhost:8080

# Sub-path the API is served under. Empty in dev (API at the domain root/:8080).
# For the single-domain layout (somedomain.com/api), set this to: /api
API_BASE_PATH=
