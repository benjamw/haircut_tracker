{
    "name": "haircut-tracker/api",
    "description": "Haircut Tracker API (Slim 4 + MySQL)",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "phpmailer/phpmailer": "^6.9",
        "lbuchs/webauthn": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "robmorgan/phinx": "^0.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
