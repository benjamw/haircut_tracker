# Defensive wrapper for Apache/shared hosting.
#
# Preferred deployment: upload the contents of web/dist/ to the web docroot.
# If the host can only point the docroot at web/, this file serves the built
# React app from web/dist/ and blocks source/dependency/config files.
Options -Indexes

<FilesMatch "(^\.|^(package(-lock)?\.json|vite\.config\.ts|tsconfig\.json|Dockerfile)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Do not serve raw TypeScript/source files or local dependencies.
    RewriteRule ^(?:node_modules|public|src)(?:/|$) - [F,L,NC]

    # Serve built static assets from dist/ when they exist.
    RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
    RewriteRule ^(.+)$ dist/$1 [L]

    # SPA fallback for /admin and other client-side routes.
    RewriteRule ^$ dist/index.html [L]
    RewriteRule . dist/index.html [L]
</IfModule>

<IfModule !mod_rewrite.c>
    DirectoryIndex dist/index.html
</IfModule>